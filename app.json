{
  "expo": {
    "name": "3elagi",
    "slug": "3elagi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "threelagi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-logo.png",
      "backgroundColor": "#f5f7fa",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.threelagi.mobile"
    },
    "android": {
      "package": "com.threelagi.mobile",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#3057F2"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "./plugins/withAndroidLaunchBackground.js",
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "react-native-document-scanner-plugin",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow 3elagi to access your photos and videos for chat and medical records.",
          "cameraPermission": "Allow 3elagi to use the camera for photos, videos, and medical records."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow 3elagi to record voice messages."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "chat-messages",
          "color": "#3057F2"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "backgroundColor": "#f5f7fa",
          "imageWidth": 280,
          "android": {
            "image": "./assets/images/splash-logo.png",
            "backgroundColor": "#f5f7fa",
            "imageWidth": 280,
            "resizeMode": "contain"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c4d6c5d2-8664-4a92-b30a-2205f11532b5"
      }
    }
  }
}
